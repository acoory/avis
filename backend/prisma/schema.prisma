generator client {
  provider               = "prisma-client"
  output                 = "./generated"
  moduleFormat           = "cjs"
  generatedFileExtension = "cts"
  importFileExtension    = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  COLLABORATOR
}

enum VehicleCheckStatus {
  DRAFT
  TO_ANALYZE
  SUMMARY_READY
  CLOSED_NO_DAMAGE
  COMPLETED
  CANCELLED
}

enum RepairDecisionStatus {
  ACCEPTED
  TO_CHECK
  NOT_PROFITABLE
  FORBIDDEN
  MANDATORY
  WARNING
}

enum ManufacturerRepairRuleStatus {
  ALLOWED
  FORBIDDEN
  TO_CHECK
  MANDATORY
  CONDITIONAL
}

enum PartOrderStatus {
  NOT_REQUIRED
  TO_ORDER
  ORDERED
}

enum VehicleCheckItemOperationalStatus {
  ACTIVE
  IMPOSSIBLE
  CANCELLED
}

enum VehicleCheckConversationStatus {
  OPEN
  RESOLVED
  CLOSED
}

enum VehicleCheckConversationParticipantRole {
  REQUESTER
  DECISION_MAKER
  OBSERVER
}

enum NotificationType {
  CONVERSATION_MESSAGE
  CONVERSATION_PARTICIPANT_ADDED
  CONVERSATION_STATUS_CHANGED
  TAKEN_IN_CHARGE
  VEHICLE_RECOVERED
}

enum NotificationEmailStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

model User {
  id                             String    @id @default(uuid())
  email                          String    @unique
  password                       String
  firstName                      String
  lastName                       String
  role                           Role      @default(COLLABORATOR)
  refreshTokenHash               String?
  publicAccessCodeHash           String?
  publicAccessCodeEncrypted      String?
  publicAccessCodeFingerprint    String?   @unique
  publicAccessCodeVersion        Int       @default(0)
  publicAccessCodeIssuedAt       DateTime?
  publicAccessCodeFailedAttempts Int       @default(0)
  publicAccessCodeLockedUntil    DateTime?
  publicAccessCodeLastEmailedAt  DateTime?
  publicAccessCodeEmailWindowAt  DateTime?
  publicAccessCodeEmailCount     Int       @default(0)
  isActive                       Boolean   @default(true)
  lastLoginAt                    DateTime?
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt

  vehicleChecks                          VehicleCheck[]                        @relation("VehicleCheckCollaborator")
  managerAssignments                     UserManagerAssignment[]               @relation("CollaboratorManagerAssignments")
  managedCollaboratorAssignments         UserManagerAssignment[]               @relation("ManagerCollaboratorAssignments")
  createdManagerAssignments              UserManagerAssignment[]               @relation("CreatedManagerAssignments")
  vehicleCheckItemStatusHistories        VehicleCheckItemStatusHistory[]
  externalRepairCompanies                ExternalRepairCompany[]               @relation("ExternalRepairCompanyCreatedBy")
  externalRepairContacts                 ExternalRepairContact[]               @relation("ExternalRepairContactCreatedBy")
  vehicleCheckPublicShares               VehicleCheckPublicShare[]             @relation("VehicleCheckPublicShareCreatedBy")
  vehicleRecoveredPublicShares           VehicleCheckPublicShare[]             @relation("VehicleCheckPublicShareRecoveredBy")
  vehicleCheckDecisionShares             VehicleCheckDecisionShare[]           @relation("VehicleCheckDecisionShareManager")
  createdVehicleCheckDecisionShares      VehicleCheckDecisionShare[]           @relation("VehicleCheckDecisionShareCreatedBy")
  createdVehicleCheckConversations       VehicleCheckConversation[]            @relation("VehicleCheckConversationCreatedBy")
  vehicleCheckConversationParticipants   VehicleCheckConversationParticipant[]
  vehicleCheckMessages                   VehicleCheckMessage[]                 @relation("VehicleCheckMessageAuthor")
  uploadedVehicleCheckMessageAttachments VehicleCheckMessageAttachment[]       @relation("VehicleCheckMessageAttachmentUploadedBy")
  receivedNotifications                  Notification[]                        @relation("NotificationRecipient")
  actedNotifications                     Notification[]                        @relation("NotificationActor")
  publicAccessSessions                   PublicAccessSession[]

  @@index([role])
  @@index([isActive])
}

model PublicAccessSession {
  id            String    @id @default(uuid())
  userId        String
  tokenHash     String    @unique
  codeVersion   Int
  userAgentHash String?
  expiresAt     DateTime
  lastUsedAt    DateTime  @default(now())
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt])
  @@index([expiresAt])
}

model UserManagerAssignment {
  id             String    @id @default(uuid())
  collaboratorId String
  managerId      String
  isPrimary      Boolean   @default(false)
  isActive       Boolean   @default(true)
  assignedAt     DateTime  @default(now())
  unassignedAt   DateTime?
  createdById    String?

  collaborator User  @relation("CollaboratorManagerAssignments", fields: [collaboratorId], references: [id], onDelete: Cascade)
  manager      User  @relation("ManagerCollaboratorAssignments", fields: [managerId], references: [id], onDelete: Cascade)
  createdBy    User? @relation("CreatedManagerAssignments", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([collaboratorId, managerId])
  @@index([collaboratorId, isActive])
  @@index([managerId, isActive])
  @@index([createdById])
}

model Agency {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  city      String
  region    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicleChecks VehicleCheck[]

  @@unique([name, city])
  @@index([city])
  @@index([region])
  @@index([isActive])
}

model Manufacturer {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  models      VehicleModel[]
  rule        ManufacturerRule?
  repairRules ManufacturerRepairRule[]
  checks      VehicleCheck[]
}

model VehicleModel {
  id             String   @id @default(uuid())
  manufacturerId String
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  manufacturer Manufacturer   @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
  checks       VehicleCheck[]

  @@unique([manufacturerId, name])
  @@index([manufacturerId])
}

model RepairType {
  id                          String   @id @default(uuid())
  name                        String
  code                        String   @unique
  defaultInternalSavingAmount Decimal  @default(0) @db.Decimal(12, 2)
  isActive                    Boolean  @default(true)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  manufacturerRepairRules ManufacturerRepairRule[]
  vehicleCheckItems       VehicleCheckItem[]
  externalQuoteItems      ExternalQuoteItem[]

  @@index([isActive])
}

model VehiclePart {
  id           String   @id @default(uuid())
  name         String
  code         String   @unique
  category     String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  manufacturerRepairRules ManufacturerRepairRule[]
  vehicleCheckItems       VehicleCheckItem[]

  @@index([category])
  @@index([displayOrder])
  @@index([isActive])
}

model ManufacturerRule {
  id                         String   @id @default(uuid())
  manufacturerId             String   @unique
  constructorAllowanceAmount Decimal  @default(0) @db.Decimal(12, 2)
  laborRate                  Decimal? @db.Decimal(12, 2)
  paintRate                  Decimal? @db.Decimal(12, 2)
  partsDiscountRate          Decimal? @db.Decimal(5, 2)
  dentRemovalCost            Decimal? @db.Decimal(12, 2)
  servicingCost              Decimal? @db.Decimal(12, 2)
  revisionRequired           Boolean  @default(false)
  notes                      String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  manufacturer Manufacturer @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
}

model ManufacturerRepairRule {
  id                         String                       @id @default(uuid())
  manufacturerId             String
  repairTypeId               String
  vehiclePartId              String?
  status                     ManufacturerRepairRuleStatus @default(ALLOWED)
  allowed                    Boolean                      @default(true)
  mandatory                  Boolean                      @default(false)
  thresholdAmount            Decimal?                     @db.Decimal(12, 2)
  thresholdPercentage        Decimal?                     @db.Decimal(5, 2)
  customInternalSavingAmount Decimal?                     @db.Decimal(12, 2)
  customInternalCost         Decimal?                     @db.Decimal(12, 2)
  comment                    String?
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt

  manufacturer Manufacturer @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
  repairType   RepairType   @relation(fields: [repairTypeId], references: [id], onDelete: Cascade)
  vehiclePart  VehiclePart? @relation(fields: [vehiclePartId], references: [id], onDelete: Cascade)

  @@unique([manufacturerId, repairTypeId, vehiclePartId])
  @@index([manufacturerId])
  @@index([repairTypeId])
  @@index([vehiclePartId])
  @@index([status])
}

model VehicleCheck {
  id                                String             @id @default(uuid())
  checkNumber                       String             @unique
  collaboratorId                    String
  agencyId                          String
  manufacturerId                    String
  vehicleModelId                    String?
  licensePlate                      String
  licensePlateRaw                   String?
  licensePlateCountry               String             @default("FR")
  licensePlateRecognitionConfidence Float?
  mileage                           Int?
  checkDate                         DateTime           @default(now())
  city                              String
  status                            VehicleCheckStatus @default(DRAFT)
  totalInternalSavingAmount         Decimal            @default(0) @db.Decimal(12, 2)
  totalInternalCost                 Decimal            @default(0) @db.Decimal(12, 2)
  totalExternalCost                 Decimal            @default(0) @db.Decimal(12, 2)
  totalDifferenceAmount             Decimal            @default(0) @db.Decimal(12, 2)
  constructorAllowanceAmount        Decimal            @default(0) @db.Decimal(12, 2)
  allowanceDifferenceAmount         Decimal            @default(0) @db.Decimal(12, 2)
  decisionSummary                   String?
  notes                             String?
  fieldCompletedAt                  DateTime?
  summaryFinalizedAt                DateTime?
  createdAt                         DateTime           @default(now())
  updatedAt                         DateTime           @updatedAt

  collaborator   User                        @relation("VehicleCheckCollaborator", fields: [collaboratorId], references: [id], onDelete: Restrict)
  agency         Agency                      @relation(fields: [agencyId], references: [id], onDelete: Restrict)
  manufacturer   Manufacturer                @relation(fields: [manufacturerId], references: [id], onDelete: Restrict)
  vehicleModel   VehicleModel?               @relation(fields: [vehicleModelId], references: [id], onDelete: SetNull)
  items          VehicleCheckItem[]
  externalQuotes ExternalQuote[]
  publicShare    VehicleCheckPublicShare?
  decisionShares VehicleCheckDecisionShare[]
  conversation   VehicleCheckConversation?
  notifications  Notification[]

  @@unique([licensePlateCountry, licensePlate])
  @@index([collaboratorId])
  @@index([agencyId])
  @@index([manufacturerId])
  @@index([vehicleModelId])
  @@index([checkDate])
  @@index([status])
  @@index([licensePlate])
  @@index([licensePlateCountry])
}

model ExternalRepairCompany {
  id          String   @id @default(uuid())
  name        String   @unique
  notes       String?
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User?                   @relation("ExternalRepairCompanyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  contacts  ExternalRepairContact[]

  @@index([isActive])
  @@index([createdById])
  @@index([name])
}

model ExternalRepairContact {
  id          String   @id @default(uuid())
  name        String
  companyName String?
  companyId   String?
  email       String   @unique
  phone       String?
  notes       String?
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy    User?                     @relation("ExternalRepairContactCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  company      ExternalRepairCompany?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  publicShares VehicleCheckPublicShare[]

  @@index([isActive])
  @@index([createdById])
  @@index([companyId])
  @@index([companyName])
}

model VehicleCheckPublicShare {
  id                      String    @id @default(uuid())
  vehicleCheckId          String    @unique
  externalRepairContactId String?
  token                   String    @unique
  isEnabled               Boolean   @default(true)
  takenInChargeAt         DateTime?
  vehicleRecoveredAt      DateTime?
  vehicleRecoveredById    String?
  createdById             String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  vehicleCheck          VehicleCheck           @relation(fields: [vehicleCheckId], references: [id], onDelete: Cascade)
  externalRepairContact ExternalRepairContact? @relation(fields: [externalRepairContactId], references: [id], onDelete: SetNull)
  createdBy             User?                  @relation("VehicleCheckPublicShareCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  vehicleRecoveredBy    User?                  @relation("VehicleCheckPublicShareRecoveredBy", fields: [vehicleRecoveredById], references: [id], onDelete: SetNull)

  @@index([token])
  @@index([isEnabled])
  @@index([externalRepairContactId])
  @@index([takenInChargeAt])
  @@index([vehicleRecoveredAt])
  @@index([vehicleRecoveredById])
  @@index([createdById])
}

model VehicleCheckDecisionShare {
  id             String    @id @default(uuid())
  vehicleCheckId String
  managerId      String
  token          String    @unique
  isEnabled      Boolean   @default(true)
  requestComment String?
  emailSentAt    DateTime?
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  vehicleCheck VehicleCheck @relation(fields: [vehicleCheckId], references: [id], onDelete: Cascade)
  manager      User         @relation("VehicleCheckDecisionShareManager", fields: [managerId], references: [id], onDelete: Restrict)
  createdBy    User?        @relation("VehicleCheckDecisionShareCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([vehicleCheckId, managerId])
  @@index([vehicleCheckId])
  @@index([managerId])
  @@index([token])
  @@index([isEnabled])
  @@index([emailSentAt])
  @@index([createdById])
}

model VehicleCheckConversation {
  id             String                         @id @default(uuid())
  vehicleCheckId String                         @unique
  createdById    String?
  status         VehicleCheckConversationStatus @default(OPEN)
  resolvedAt     DateTime?
  closedAt       DateTime?
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt

  vehicleCheck  VehicleCheck                          @relation(fields: [vehicleCheckId], references: [id], onDelete: Cascade)
  createdBy     User?                                 @relation("VehicleCheckConversationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  participants  VehicleCheckConversationParticipant[]
  messages      VehicleCheckMessage[]
  notifications Notification[]

  @@index([createdById])
  @@index([status])
  @@index([updatedAt])
}

model VehicleCheckConversationParticipant {
  id                        String                                  @id @default(uuid())
  conversationId            String
  userId                    String
  role                      VehicleCheckConversationParticipantRole
  emailNotificationsEnabled Boolean                                 @default(true)
  joinedAt                  DateTime                                @default(now())
  lastReadAt                DateTime?

  conversation VehicleCheckConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId, lastReadAt])
}

model VehicleCheckMessage {
  id             String    @id @default(uuid())
  conversationId String
  authorId       String?
  body           String?
  createdAt      DateTime  @default(now())
  editedAt       DateTime?

  conversation  VehicleCheckConversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author        User?                           @relation("VehicleCheckMessageAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  attachments   VehicleCheckMessageAttachment[]
  mentions      VehicleCheckMessageMention[]
  notifications Notification[]

  @@index([conversationId, createdAt])
  @@index([authorId])
}

model VehicleCheckMessageAttachment {
  id           String   @id @default(uuid())
  messageId    String
  uploadedById String?
  publicId     String   @unique
  resourceType String
  secureUrl    String
  originalName String
  mimeType     String
  bytes        Int
  format       String?
  createdAt    DateTime @default(now())

  message    VehicleCheckMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploadedBy User?               @relation("VehicleCheckMessageAttachmentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([messageId])
  @@index([uploadedById])
  @@index([createdAt])
}

model VehicleCheckMessageMention {
  id                 String @id @default(uuid())
  messageId          String
  vehicleCheckItemId String
  label              String

  message          VehicleCheckMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  vehicleCheckItem VehicleCheckItem    @relation(fields: [vehicleCheckItemId], references: [id], onDelete: Cascade)

  @@unique([messageId, vehicleCheckItemId])
  @@index([vehicleCheckItemId])
}

model Notification {
  id             String           @id @default(uuid())
  recipientId    String
  actorId        String?
  type           NotificationType
  vehicleCheckId String?
  conversationId String?
  messageId      String?
  title          String
  excerpt        String?
  route          String
  createdAt      DateTime         @default(now())
  readAt         DateTime?

  recipient    User                      @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor        User?                     @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  vehicleCheck VehicleCheck?             @relation(fields: [vehicleCheckId], references: [id], onDelete: Cascade)
  conversation VehicleCheckConversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      VehicleCheckMessage?      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  email        NotificationEmail?

  @@index([recipientId, readAt, createdAt])
  @@index([vehicleCheckId])
  @@index([conversationId])
  @@index([messageId])
}

model NotificationEmail {
  id                  String                  @id @default(uuid())
  notificationId      String                  @unique
  recipientEmail      String
  subject             String
  text                String
  html                String
  status              NotificationEmailStatus @default(PENDING)
  attempts            Int                     @default(0)
  lastError           String?
  sentAt              DateTime?
  processingStartedAt DateTime?
  nextAttemptAt       DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([status, nextAttemptAt, createdAt])
}

model VehicleCheckItem {
  id                        String                            @id @default(uuid())
  vehicleCheckId            String
  repairTypeId              String
  vehiclePartId             String
  quantity                  Int                               @default(1)
  unitInternalSavingAmount  Decimal                           @default(0) @db.Decimal(12, 2)
  totalInternalSavingAmount Decimal                           @default(0) @db.Decimal(12, 2)
  unitInternalCost          Decimal                           @default(0) @db.Decimal(12, 2)
  totalInternalCost         Decimal                           @default(0) @db.Decimal(12, 2)
  decisionStatus            RepairDecisionStatus              @default(ACCEPTED)
  decisionMessage           String?
  comment                   String?
  operationalStatus         VehicleCheckItemOperationalStatus @default(ACTIVE)
  operationalComment        String?
  selectedForSummary        Boolean                           @default(true)
  partOrderRequired         Boolean                           @default(false)
  partOrderStatus           PartOrderStatus                   @default(NOT_REQUIRED)
  partOrderPrice            Decimal?                          @db.Decimal(12, 2)
  partOrderReference        String?
  partOrderedAt             DateTime?
  createdAt                 DateTime                          @default(now())
  updatedAt                 DateTime                          @updatedAt

  vehicleCheck    VehicleCheck                    @relation(fields: [vehicleCheckId], references: [id], onDelete: Cascade)
  repairType      RepairType                      @relation(fields: [repairTypeId], references: [id], onDelete: Restrict)
  vehiclePart     VehiclePart                     @relation(fields: [vehiclePartId], references: [id], onDelete: Restrict)
  statusHistories VehicleCheckItemStatusHistory[]
  photos          VehicleCheckItemPhoto[]
  messageMentions VehicleCheckMessageMention[]

  @@index([vehicleCheckId])
  @@index([repairTypeId])
  @@index([vehiclePartId])
  @@index([decisionStatus])
  @@index([operationalStatus])
  @@index([partOrderStatus])
}

model VehicleCheckItemPhoto {
  id                 String   @id @default(uuid())
  vehicleCheckItemId String
  publicId           String   @unique @map("cloudinaryPublicId")
  assetId            String?  @map("cloudinaryAssetId")
  secureUrl          String
  width              Int
  height             Int
  bytes              Int
  format             String
  createdAt          DateTime @default(now())

  vehicleCheckItem VehicleCheckItem @relation(fields: [vehicleCheckItemId], references: [id], onDelete: Cascade)

  @@index([vehicleCheckItemId])
  @@index([createdAt])
}

model VehicleCheckItemStatusHistory {
  id                 String                            @id @default(uuid())
  vehicleCheckItemId String
  userId             String?
  fromStatus         VehicleCheckItemOperationalStatus
  toStatus           VehicleCheckItemOperationalStatus
  comment            String?
  createdAt          DateTime                          @default(now())

  vehicleCheckItem VehicleCheckItem @relation(fields: [vehicleCheckItemId], references: [id], onDelete: Cascade)
  user             User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([vehicleCheckItemId])
  @@index([userId])
  @@index([createdAt])
}

model ExternalQuote {
  id             String   @id @default(uuid())
  vehicleCheckId String
  expertName     String
  quoteReference String?
  quoteDate      DateTime @default(now())
  totalAmount    Decimal  @default(0) @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vehicleCheck VehicleCheck        @relation(fields: [vehicleCheckId], references: [id], onDelete: Cascade)
  items        ExternalQuoteItem[]

  @@index([vehicleCheckId])
  @@index([quoteDate])
}

model ExternalQuoteItem {
  id              String   @id @default(uuid())
  externalQuoteId String
  repairTypeId    String?
  label           String
  quantity        Int      @default(1)
  unitPrice       Decimal  @default(0) @db.Decimal(12, 2)
  totalPrice      Decimal  @default(0) @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  externalQuote ExternalQuote @relation(fields: [externalQuoteId], references: [id], onDelete: Cascade)
  repairType    RepairType?   @relation(fields: [repairTypeId], references: [id], onDelete: SetNull)

  @@index([externalQuoteId])
  @@index([repairTypeId])
}
